# ─────────────────────────────────────────────────────────────────────────────
# Solaris Diamond — environment variables
# Copy to `.env` and fill in. DATABASE_URL and Supabase keys are REQUIRED.
# PayMongo and Resend are optional — the app degrades gracefully without them.
# ─────────────────────────────────────────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# PostgreSQL (Prisma) — REQUIRED
DATABASE_URL="postgresql://user:password@host:5432/solaris?sslmode=require"

# Supabase Auth + Storage — REQUIRED
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# PayMongo (payments) — optional, falls back to mock checkout
NEXT_PUBLIC_PAYMONGO_PUBLIC_KEY="pk_test_xxx"
PAYMONGO_SECRET_KEY="sk_test_xxx"
PAYMONGO_WEBHOOK_SECRET="whsk_xxx"

# Resend (transactional email) — optional, logs to console if missing
RESEND_API_KEY="re_xxx"
EMAIL_FROM="Solaris Diamond <noreply@yourdomain.com>"

# Admin seed — set ADMIN_AUTH_ID to the Supabase Auth UUID of the admin user
ADMIN_EMAIL="admin@solarisdiamond.com"
ADMIN_NAME="System Administrator"
ADMIN_AUTH_ID=""

# Cron secret — protects /api/cron/* endpoints
CRON_SECRET="your-cron-secret"

# Observability (optional)
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_SENTRY_DSN=""
